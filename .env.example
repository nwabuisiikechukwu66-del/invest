# ─────────────────────────────────────────────────────────────────────────────
# REALTYINVESTORS — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME=RealtyInvestors
VITE_APP_URL=http://localhost:5173

# ── Supabase Service Role (server-side / Edge Functions only — NEVER expose to browser) ──
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── Email (optional — via Supabase SMTP or Resend) ───────────────────────────
RESEND_API_KEY=your-resend-api-key-here
EMAIL_FROM=noreply@realtyinvestors.com

# ── Storage ───────────────────────────────────────────────────────────────────
VITE_SUPABASE_STORAGE_BUCKET=property-documents
