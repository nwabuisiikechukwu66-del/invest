.env
.env.local
.env.*.local
.env.production

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
dist/
build/
.output/

# Vite
.vite/

# Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log

# TypeScript
*.tsbuildinfo

# Supabase local dev
supabase/.branches/
supabase/.temp/

# Coverage
coverage/
.nyc_output/
